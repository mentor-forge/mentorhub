# MentorHub AWS platform defaults for Developer Edition tooling.
# Installed to ~/.mentorhub/aws-platform.env by make install / make update.
# Canonical record: Specifications/aws-platform.yaml

# Workload region (CodeArtifact, CLI --region, GitHub Actions)
export AWS_REGION=us-east-1

# IAM Identity Center (SSO sign-in only — not the workload region)
export SSO_SESSION_NAME=mentor-forge
export SSO_START_URL=https://d-9a67582559.awsapps.com/start
export SSO_REGION=us-east-2

# AWS CLI profile for CodeArtifact (make aws-setup writes ~/.aws/config)
export MH_AWS_PROFILE_SHARED=mentorhub-shared
export MH_AWS_SSO_ROLE_SHARED=Developer-Packages

# Shared-Services / CodeArtifact
export AWS_SHARED_SERVICES_ACCOUNT_ID=560167829275
export CODEARTIFACT_DOMAIN=mentor-forge
export CODEARTIFACT_DOMAIN_OWNER=560167829275
export CODEARTIFACT_PYPI_REPO=mentorhub-pypi
export CODEARTIFACT_NPM_REPO=mentorhub-npm

# GitHub Container Registry
export MH_GHCR_ORG=mentor-forge
